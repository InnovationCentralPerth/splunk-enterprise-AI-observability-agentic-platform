# ── Meraki ────────────────────────────────────────────────────────────────────
MERAKI_API_KEY=your_meraki_api_key_here
MERAKI_ORG_ID=your_meraki_org_id_here
MERAKI_NETWORK_ID=your_meraki_network_id_here

# ── Splunk HEC ────────────────────────────────────────────────────────────────
SPLUNK_HEC_URL=https://127.0.0.1:8088/services/collector
SPLUNK_HEC_TOKEN=your_splunk_hec_token_here
SPLUNK_HOST=your-splunk-hostname

# ── OpenRouter AI (https://openrouter.ai) ─────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://your-org-url.example.com

# ── Models — free tier options; upgrade as needed ─────────────────────────────
# MODEL_ANALYST runs scheduled building summaries (more capable model preferred)
# MODEL_COMPOSER handles interactive chat (fast response preferred)
# MODEL_FALLBACK is used if MODEL_COMPOSER times out
MODEL_ANALYST=openai/gpt-oss-120b:free
MODEL_COMPOSER=meta-llama/llama-3.3-70b-instruct:free
MODEL_FALLBACK=openai/gpt-oss-20b:free

# ── Polling ───────────────────────────────────────────────────────────────────
# Interval in seconds between Meraki API polls (120 = 2 minutes)
POLL_INTERVAL=120
